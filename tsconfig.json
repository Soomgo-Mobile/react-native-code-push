{
  "compilerOptions": {
    "target": "ES5",
    "module": "commonjs",
    "lib": ["es6"],
    "esModuleInterop": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "noEmit": true,
    "rootDir": "src",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "Examples/**",
    "code-push.config.example.*"
  ]
}
